# ============================================
# AI Patient Pre-Diagnosis Agent - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git!

# --- Google Gemini API (Server-side ONLY) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Supabase (Free tier - no CC required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Clerk Auth (Free tier - 10k MAU, no CC) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Email (Nodemailer SMTP) ---
# Brevo SMTP (Free: 300 emails/day) or Gmail SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="MedAssist AI <noreply@yoursite.com>"

# --- PostHog Analytics (Free tier - 1M events/mo, no CC) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry Error Tracking (Free tier - 5k errors/mo, no CC) ---
SENTRY_DSN=https://your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# --- Rate Limiting (Upstash Free tier or in-memory for dev) ---
# Leave empty to use in-memory rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron Jobs (Vercel built-in) ---
CRON_SECRET=generate_a_random_32_character_string_here

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
